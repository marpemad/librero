# --- Telegram ---
TELEGRAM_BOT_TOKEN=tu_token_de_botfather

# Restringe el bot a tu propio user_id (sepáralo por comas si quieres varios)
ALLOWED_USER_IDS=123456789

# --- LLM ---
# Proveedor activo: "gemini" (nube, recomendado) o "ollama" (local)
# Por defecto usa Gemini. Para Ollama local, ejecuta con:
#   docker compose --profile local up -d
LLM_PROVIDER=gemini

# Ollama (solo si LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.6:27b-q4_K_M
# Alternativas: llama3.1:8b, mistral:7b, phi3:mini

# Gemini (solo si LLM_PROVIDER=gemini)
# Obtén tu API key en: aistudio.google.com/apikey
GEMINI_API_KEY=tu_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
# Modelos disponibles: gemini-2.0-flash · gemini-2.5-pro · gemini-1.5-pro

# --- Obsidian ---
OBSIDIAN_VAULT_PATH=/Users/tu_usuario/Documents/ObsidianVault
OBSIDIAN_INBOX_FOLDER=00_Inbox

# --- Whisper (faster-whisper) ---
# tiny | base | small | medium | large-v3
WHISPER_MODEL=small
# En M1: "auto" detecta Metal. Usa "cpu" si tienes problemas.
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# --- Carpeta temporal para descargas ---
TEMP_DIR=/tmp/librero

# --- Chunking (Fase 1) ---
# Por encima de este nº de caracteres se activa el modo map-reduce.
CHUNK_THRESHOLD_CHARS=20000
# Tamaño objetivo de cada chunk (caracteres).
CHUNK_SIZE_CHARS=12000
# Solapamiento entre chunks consecutivos (preserva continuidad).
CHUNK_OVERLAP_CHARS=500
# Si el contenido supera esto, el bot pide confirmación antes de procesar.
CONFIRM_THRESHOLD_CHARS=50000

# --- Caché ---
# SQLite con resultados de extracciones costosas (Whisper, PDFs grandes).
CACHE_DB_PATH=/tmp/librero/cache.db

# --- Google Calendar ---
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
#             → Create credentials → OAuth client ID → Desktop app
GCAL_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GCAL_CLIENT_SECRET=tu_client_secret

# Token OAuth2 guardado automáticamente tras /calauth (no tocar a mano)
GCAL_TOKEN_PATH=~/.config/librero/gcal_token.json

# BD SQLite para preferencias de notificación de eventos
GCAL_NOTIFY_DB_PATH=/tmp/librero/gcal_notify.db

# Puerto local para el servidor OAuth2 temporal (solo durante /calauth)
GCAL_AUTH_PORT=8765

# Hora del resumen diario automático (formato HH:MM, hora local)
GCAL_DAILY_SUMMARY_TIME=08:00
