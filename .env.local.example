# .env.local.example — Configuración para modo LOCAL con Ollama
#
# Copia este archivo a .env.local y rellena las variables:
#     cp .env.local.example .env.local
#
# USO con Docker Compose:
#     docker compose -f docker-compose.yml -f docker-compose.local.yml up -d
#
# O si renombras docker-compose.local.yml a docker-compose.override.yml:
#     docker compose --profile local up -d

# --- Telegram ---
TELEGRAM_BOT_TOKEN=tu_token_de_botfather
ALLOWED_USER_IDS=123456789

# --- LLM: Ollama Local ---
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b-q8_0
# Alternativas: llama3.1:8b, mistral:7b, phi3:mini, qwen2.5:7b, etc.

# --- Obsidian Vault ---
OBSIDIAN_VAULT_PATH=/Users/tu_usuario/Documents/ObsidianVault
OBSIDIAN_INBOX_FOLDER=00_Inbox

# --- Whisper ---
WHISPER_MODEL=small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# --- Directorio temporal ---
TEMP_DIR=/tmp/librero

# --- Chunking ---
CHUNK_THRESHOLD_CHARS=20000
CHUNK_SIZE_CHARS=12000
CHUNK_OVERLAP_CHARS=500
CONFIRM_THRESHOLD_CHARS=50000

# --- Caché ---
CACHE_DB_PATH=/tmp/librero/cache.db
